\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{config/presentation-style}[2026/07/21 WEAiL presentation theme]

\RequirePackage{iftex}
\ifPDFTeX
  \PackageError{presentation-style}{Ten szablon wymaga LuaLaTeX}{Uruchom latexmk main.tex.}
\else
  \RequirePackage{fontspec}
  \defaultfontfeatures{Ligatures=TeX}
  \IfFontExistsTF{Aptos}{\setsansfont{Aptos}}{%
    \IfFontExistsTF{Arial}{\setsansfont{Arial}}{\setsansfont{TeX Gyre Heros}}}
  \IfFontExistsTF{Consolas}{\setmonofont{Consolas}}{\setmonofont{Latin Modern Mono}}
\fi

\RequirePackage[polish,english]{babel}
\RequirePackage{etoolbox}
\RequirePackage{graphicx}
\RequirePackage{booktabs}
\RequirePackage{tabularx}
\RequirePackage{ragged2e}
\RequirePackage{listings}
\RequirePackage{tikz}
\RequirePackage{csquotes}
\RequirePackage[backend=biber,style=numeric,sorting=none]{biblatex}
\addbibresource{bibliografia.bib}

